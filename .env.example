# Smith AI - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Groq - LLM
GROQ_API_KEY=your_groq_api_key_here

# Groq - Whisper Large v3 (Speech-to-Text)
GROQ_WHISPER_API_KEY=your_groq_whisper_key_here

# Gemini - Resume Intelligence System (Resume Parsing & Extraction)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS origin for frontend (comma-separated for multiple)
# In production, set this to your Vercel URL
CLIENT_ORIGINS=http://localhost:5173
